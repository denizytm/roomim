# Supabase — local development values are printed by `npx supabase status`.
# For a hosted project use the Project Settings → API values (eu-central / Frankfurt for KVKK).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used for auth email redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
